<!DOCTYPE html>
<html lang="he" dir="rtl">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">

<title>TAKI GAME</title>


<style>

body{

margin:0;
font-family:Arial;
background:linear-gradient(135deg,#111,#444);
color:white;
text-align:center;

}


.box{

max-width:650px;
margin:20px auto;
background:#222;
padding:20px;
border-radius:30px;
box-shadow:0 0 40px black;

}


h1{

font-size:45px;
animation:pulse 2s infinite;

}


@keyframes pulse{

50%{

transform:scale(1.05);

}

}



button{

padding:12px 25px;
border:0;
border-radius:20px;
font-size:18px;
cursor:pointer;
margin:5px;

}



.cards{

display:flex;
justify-content:center;
flex-wrap:wrap;
gap:8px;

}




.card{

width:60px;
height:90px;
background:white;
border-radius:15px;
display:flex;
justify-content:center;
align-items:center;
font-size:30px;
font-weight:bold;
cursor:pointer;
animation:pop .3s;

}



@keyframes pop{

from{

transform:scale(0);

}

}



.red{color:red}
.blue{color:blue}
.green{color:green}
.yellow{color:#b88600}



.skin1{

background:white;

}



.skin2{

background:#111;
color:white;

}



.skin3{

background:gold;

}



.back{

background:#111;
color:white;

}




.bot{

background:#333;
padding:10px;
border-radius:20px;
margin:10px;

}



.center{

display:flex;
justify-content:center;
gap:30px;

}



#game{

display:none;

}


#confetti{

position:fixed;
top:0;
left:0;
pointer-events:none;

}


#rules{

display:none;
background:#333;
padding:15px;
border-radius:20px;

}


</style>

</head>



<body>


<canvas id="confetti"></canvas>




<div class="box" id="home">


<h1>🃏 TAKI GAME</h1>


<p>משחק טאקי מול 2 בוטים</p>



<button onclick="showRules()">
📖 הוראות
</button>


<button onclick="start()">
🎮 התחל משחק
</button>




<div id="rules">


<h2>איך משחקים?</h2>


<p>

🃏 שמים קלף עם אותו צבע או אותו מספר<br><br>

🃏 אם אין קלף מתאים לוקחים מהקופה<br><br>

🤖 אחרי התור שלך שני הבוטים משחקים<br><br>

🏆 מי שנגמרים לו הקלפים ראשון מנצח<br><br>

🪙 ניצחון נותן מטבעות וניקוד

</p>



<button onclick="hideRules()">
סגור
</button>


</div>



</div>







<div class="box" id="game">


<h1>🃏 TAKI</h1>


<h3>

שלב:
<span id="level">1</span>

<br>

🪙 מטבעות:
<span id="coins">0</span>

<br>

🏆 ניקוד:
<span id="score">0</span>

</h3>



<div class="bot">

<h2>🤖 בוט 1</h2>

<div id="bot1" class="cards"></div>

</div>




<div class="bot">

<h2>🤖 בוט 2</h2>

<div id="bot2" class="cards"></div>

</div>





<div class="center">


<div>

<p>קופה</p>


<div class="card back" onclick="takeCard()">

🃏

</div>


</div>




<div>

<p>קלף אחרון</p>


<div id="last" class="card"></div>


</div>


</div>





<h2>הקלפים שלך</h2>


<div id="player" class="cards"></div>



<h2 id="msg">
התור שלך
</h2>




<button onclick="start()">

משחק חדש

</button>



</div>










<script>


let colors=[

"red",
"blue",
"green",
"yellow"

];


let player=[];

let bot1=[];

let bot2=[];

let deck=[];

let last;


let score=0;

let coins=0;

let level=1;

let skin=1;






function showRules(){

rules.style.display="block";

}



function hideRules(){

rules.style.display="none";

}




function newCard(){

return{

num:Math.floor(Math.random()*9)+1,

color:colors[Math.floor(Math.random()*4)]

};

}




function createDeck(){

deck=[];


for(let i=0;i<100;i++){

deck.push(newCard());

}

}




function start(){


home.style.display="none";

game.style.display="block";


createDeck();



player=[];

bot1=[];

bot2=[];



for(let i=0;i<7;i++){

player.push(deck.pop());

bot1.push(deck.pop());

bot2.push(deck.pop());

}



last=deck.pop();


draw();

}




function draw(){


playerBox.innerHTML="";



player.forEach((c,i)=>{


let d=document.createElement("div");


d.className="card "+c.color+" skin"+skin;


d.innerHTML=c.num;


d.onclick=()=>play(i);


playerBox.appendChild(d);


});




showBot("bot1",bot1);

showBot("bot2",bot2);




lastBox.className="card "+last.color+" skin"+skin;


lastBox.innerHTML=last.num;


}





let playerBox=document.getElementById("player");

let lastBox=document.getElementById("last");





function showBot(id,b){


let area=document.getElementById(id);


area.innerHTML="";


b.forEach(()=>{


let c=document.createElement("div");


c.className="card back";


c.innerHTML="🃏";


area.appendChild(c);


});


}






function takeCard(){


player.push(deck.pop());


draw();


msg.innerHTML="הבוטים משחקים";


setTimeout(botTurn,1000);


}






function play(i){


let c=player[i];


if(c.color==last.color || c.num==last.num){


last=c;


player.splice(i,1);


score+=10;

coins+=5;


document.getElementById("score").innerHTML=score;

document.getElementById("coins").innerHTML=coins;


draw();



if(player.length==0){


level++;


document.getElementById("level").innerHTML=level;


win();


return;

}



setTimeout(botTurn,1000);


}

}





function botTurn(){


computer(bot1);


draw();



setTimeout(()=>{


computer(bot2);


draw();


msg.innerHTML="התור שלך";


},1000);


}





function computer(b){


let i=b.findIndex(c=>

c.color==last.color ||

c.num==last.num

);



if(i!=-1){


last=b[i];


b.splice(i,1);


}

else{


b.push(newCard());


}


}




function win(){


msg.innerHTML="🎉 ניצחת שלב!";


let c=document.getElementById("confetti");


c.width=innerWidth;

c.height=innerHeight;


let x=c.getContext("2d");



for(let i=0;i<300;i++){


x.fillStyle=
"hsl("+Math.random()*360+",100%,50%)";


x.fillRect(

Math.random()*c.width,

Math.random()*c.height,

8,

8

);


}



}



</script>


</body>

</html>
